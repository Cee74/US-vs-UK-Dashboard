                <zone h='21471' id='10' name='Sheet 2' w='83230' x='833' y='42514'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                  </zone-style>
                </zone>
                <zone h='15740' id='11' name='Sheet 3' w='83230' x='833' y='69802'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='13687' id='23' type-v2='text' w='83230' x='833' y='28827'>
                  <formatted-text>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Market Insight:</run>
                    <run>Æ&#10;&#10;</run>
                    <run fontcolor='#000000'>The results show that only Aperture by Harry Styles and I Just Might by Bruno Mars succeeded in both the US and UK markets. This indicates that audiences in both countries favored a blend of electronic dance-pop and retro disco-funk/R&amp;B styles, reflecting a balance between modern electronic production and nostalgic revival sounds.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                  </zone-style>
                </zone>
                <zone h='5817' id='24' type-v2='text' w='83230' x='833' y='63985'>
                  <formatted-text>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>The analysis indicates that Taylor Swift was the leading artist at the beginning of 2026, although her songs ranked in the Top 5 only within the UK charts.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                  </zone-style>
                </zone>
                <zone h='13774' id='25' type-v2='text' w='83230' x='833' y='85542'>
                  <formatted-text>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>The UK’s average song duration reaches 6.3 minutes, largely driven by Taylor Swift’s latest extended tracks dominating the dataset. In contrast, the US market shows a broader mix of artists, with song durations typically ranging between 3 and 4 minutes.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                  </zone-style>
                </zone>
              </zone>
              <zone fixed-size='145' h='94697' id='6' is-fixed='true' param='vert' type-v2='layout-flow' w='15104' x='84063' y='4619'>
